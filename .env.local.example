ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: TTS-Stimme wechseln (shimmer oder nova)
OPENAI_TTS_VOICE=shimmer

# Upstash Redis (für cross-device Bibliothek + Fortschritt)
# Werden bei Vercel automatisch gesetzt, wenn "Upstash for Redis"
# über Vercel → Storage hinzugefügt wird.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
